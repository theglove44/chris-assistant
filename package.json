{
  "name": "chris-assistant",
  "version": "0.1.0",
  "description": "Personal AI assistant powered by Claude, accessible via Telegram",
  "type": "module",
  "bin": {
    "chris": "bin/chris"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit && node scripts/check-esbuild-compat.js",
    "chris": "tsx src/cli/index.ts",
    "setup:calendar-helper": "bash scripts/setup-calendar-helper.sh",
    "setup:reminders-helper": "bash scripts/setup-reminders-helper.sh",
    "test": "vitest run",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:deploy": "vitepress build docs && rsync -avz --delete docs/.vitepress/dist/ christof21@100.76.138.74:~/chris-assistant-docs/"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@anthropic-ai/sdk": "^0.52.0",
    "@mozilla/readability": "^0.6.0",
    "@octokit/rest": "^21.0.0",
    "@openai/codex-sdk": "^0.111.0",
    "commander": "^13.0.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.0",
    "grammy": "^1.30.0",
    "linkedom": "^0.18.12",
    "liquidjs": "^10.25.0",
    "openai": "^6.22.0",
    "playwright": "^1.58.2",
    "pm2": "^6.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  }
}
